{
  "schema_version": "warp-cg.agent.v1",
  "name": "ethanol_xtb",
  "smiles": "CCO",
  "reference_source": {
    "kind": "xtb",
    "xtb": {
      "mode": "optimize_and_md",
      "gfn": "gfn2",
      "temperature_k": 300.0,
      "time_ps": 10.0
    }
  },
  "optimization": {
    "enabled": true,
    "source": "xtb",
    "method": "bayesian_optimization",
    "target_terms": ["bonds", "angles"],
    "max_evaluations": 64
  },
  "output": {
    "out_dir": "results/cg/ethanol_xtb",
    "mapped_trajectory": "ethanol_cg.gro",
    "write_mapping_json": true,
    "write_cg_pdb": true,
    "write_topology_itp": true,
    "write_topology_top": true,
    "write_bonded_parameter_map": true
  }
}
